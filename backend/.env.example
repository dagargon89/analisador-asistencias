CI_ENVIRONMENT = production
app.baseURL = 'https://tu-dominio.com/backend/public/'
app.forceGlobalSecureRequests = false

database.default.hostname = localhost
database.default.database = tu_base
database.default.username = tu_usuario
database.default.password = tu_password
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

# Usada por /api/chat
gemini.apiKey = ''

# Auth JWT + lockout
auth.jwtSecret = 'cambia-este-secreto-en-produccion'
auth.jwtIssuer = 'asistencias-ci4'
auth.accessTtlSeconds = 900
auth.refreshTtlSeconds = 2592000
auth.kioskTtlSeconds = 600
auth.maxFailedAttempts = 5
auth.lockoutMinutes = 10
kiosk.maxFailedAttempts = 5
kiosk.lockoutMinutes = 5

# Seeder inicial opcional
auth.bootstrapAdminEmail = 'admin@local.test'
auth.bootstrapAdminPassword = 'Admin1234!'


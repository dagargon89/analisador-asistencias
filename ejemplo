function generateMockData() {
  const records = [];
  const startDate = new Date(2025, 8, 1);
  const endDate = new Date(2026, 2, 24);

  EMPLOYEES.forEach(emp => {
    let current = new Date(startDate);
    while (current <= endDate) {
      const dow = current.getDay();
      if (dow !== 0 && dow !== 6) {
        if (Math.random() > 0.08) {
          const entryHour = 8;
          const entryMin = Math.floor(Math.random() * 45) + (Math.random() > 0.7 ? 15 : 0);
          const exitHour = 17 + Math.floor(Math.random() * 2);
          const exitMin = Math.floor(Math.random() * 60);
          const hoursWorked = (exitHour + exitMin / 60) - (entryHour + entryMin / 60);

          records.push({
            id: records.length + 1,
            employee: emp,
            date: current.toISOString().split("T")[0],
            entry: `${String(entryHour).padStart(2, "0")}:${String(entryMin).padStart(2, "0")}`,
            exit: `${String(exitHour).padStart(2, "0")}:${String(exitMin).padStart(2, "0")}`,
            hoursWorked: Math.round(hoursWorked * 100) / 100,
          });
        }
      }
      current.setDate(current.getDate() + 1);
    }
  });
  return records;
}


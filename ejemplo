              <div>
                <label style={{ display: "block", fontSize: 12, color: "#8892a8", marginBottom: 6, fontWeight: 500 }}>
                  Horas de Trabajo por Día (jornada estándar)
                </label>
                <input type="number" step="0.5" className="input-field" value={config.workingHoursPerDay}
                  onChange={e => setConfig({ ...config, workingHoursPerDay: Number(e.target.value) })} />
              </div>
            </div>

            <div style={{
              marginTop: 24, padding: 16, borderRadius: 12,
              background: "rgba(99,132,255,0.04)", border: "1px solid rgba(99,132,255,0.08)",
            }}>
              <div style={{ fontSize: 12, fontWeight: 600, color: "#818cf8", marginBottom: 8 }}>Resumen de Clasificación</div>
              <div style={{ fontSize: 12, color: "#8892a8", lineHeight: 1.8 }}>
                <span className="badge badge-green" style={{ marginRight: 8 }}>A Tiempo</span> Entrada ≤ {config.entryTime} + {config.toleranceMinutes} min<br />
                <span className="badge badge-amber" style={{ marginRight: 8 }}>Retardo</span> Entrada entre +{config.toleranceMinutes} y +{config.lateThresholdMinutes} min<br />
                <span className="badge badge-red" style={{ marginRight: 8 }}>Ret. Mayor</span> Entrada {">"} +{config.lateThresholdMinutes} min
              </div>
            </div>

            <button className="btn-primary" style={{ width: "100%", marginTop: 20, justifyContent: "center" }}
              onClick={() => setShowSettings(false)}>
              Guardar Configuración
            </button>
          </div>
        </div>
      )}

      {/* --- UPLOAD MODAL --- */}
      {showUpload && (
        <div className="modal-overlay" onClick={() => { if (!uploadProgress) setShowUpload(false); }}>
          <div className="modal-content" onClick={e => e.stopPropagation()}>
            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 24 }}>
              <div style={{ fontSize: 18, fontWeight: 700, color: "#fff" }}>Importar Archivo de Odoo</div>
              <button onClick={() => { if (!uploadProgress) setShowUpload(false); }}
                style={{ background: "none", border: "none", color: "#5a6580", cursor: "pointer", padding: 4 }}>
                <Icons.X />
              </button>
            </div>

            {uploadProgress === null ? (
              <>
                <div className="upload-zone" onClick={handleSimulateUpload}>
                  <div style={{ color: "#6384ff", marginBottom: 12 }}>
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round">
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="17 8 12 3 7 8" /><line x1="12" y1="3" x2="12" y2="15" />
                    </svg>
                  </div>
                  <div style={{ fontSize: 14, fontWeight: 600, color: "#e2e8f0", marginBottom: 4 }}>
                    Arrastra tu archivo .xlsx aquí
                  </div>
                  <div style={{ fontSize: 12, color: "#5a6580" }}>
                    o haz clic para seleccionar
                  </div>
                  <div style={{ fontSize: 11, color: "#3d4f6f", marginTop: 12 }}>
                    Formato esperado: Reporte de Asistencia de Odoo (hr.attendance)
                  </div>
                </div>

                <div style={{ marginTop: 16, padding: 14, borderRadius: 10, background: "rgba(245,158,11,0.06)", border: "1px solid rgba(245,158,11,0.12)" }}>
                  <div style={{ fontSize: 12, color: "#fbbf24", fontWeight: 600, marginBottom: 4 }}>
                    <Icons.Alert /> Proceso de Importación
                  </div>
                  <div style={{ fontSize: 11, color: "#8892a8", lineHeight: 1.6 }}>
                    1. Se leerán las filas con datos (ignorando subtotales y encabezados)<br />
                    2. Se limpiarán nombres y se normalizarán fechas/horas<br />
                    3. Se compararán contra registros existentes (por empleado + fecha + hora)<br />
                    4. Solo se insertarán registros nuevos en la BD
                  </div>
                </div>
              </>
            ) : (
              <div style={{ padding: "20px 0" }}>
                <div style={{ textAlign: "center", marginBottom: 24 }}>
                  {uploadProgress < 100 ? (
                    <>
                      <div className="pulse" style={{ fontSize: 14, fontWeight: 600, color: "#818cf8", marginBottom: 8 }}>
                        {uploadProgress < 30 ? "Leyendo archivo..." :
                          uploadProgress < 60 ? "Limpiando datos..." :
                            uploadProgress < 85 ? "Comparando con BD..." : "Insertando registros nuevos..."}
                      </div>
                      <div className="progress-bar" style={{ marginBottom: 8 }}>
                        <div className="progress-fill" style={{ width: `${Math.min(uploadProgress, 100)}%` }} />
                      </div>
                      <div style={{ fontSize: 11, color: "#5a6580", fontFamily: "'JetBrains Mono', monospace" }}>
                        {Math.round(Math.min(uploadProgress, 100))}%
                      </div>
                    </>
                  ) : (
                    <div>
                      <div style={{ width: 48, height: 48, borderRadius: 24, background: "rgba(16,185,129,0.12)", display: "flex", alignItems: "center", justifyContent: "center", margin: "0 auto 12px", color: "#34d399" }}>
                        <Icons.Check />
                      </div>
                      <div style={{ fontSize: 16, fontWeight: 700, color: "#34d399", marginBottom: 4 }}>Importación Completada</div>
                      <div style={{ fontSize: 12, color: "#5a6580" }}>Se procesaron 3,030 registros • 0 duplicados</div>
                    </div>
                  )}
                </div>

                {uploadProgress >= 30 && (
                  <div style={{ fontSize: 12, color: "#5a6580", lineHeight: 1.8, fontFamily: "'JetBrains Mono', monospace" }}>
                    <div style={{ display: "flex", gap: 8, alignItems: "center", color: "#34d399" }}>
                      <Icons.Check /> Archivo leído: 3,241 filas
                    </div>
                    {uploadProgress >= 50 && (
                      <div style={{ display: "flex", gap: 8, alignItems: "center", color: "#34d399" }}>
                        <Icons.Check /> Datos limpios: 3,030 registros válidos
                      </div>
                    )}
                    {uploadProgress >= 75 && (
                      <div style={{ display: "flex", gap: 8, alignItems: "center", color: "#34d399" }}>
                        <Icons.Check /> 34 empleados identificados
                      </div>
                    )}
                    {uploadProgress >= 95 && (
                      <div style={{ display: "flex", gap: 8, alignItems: "center", color: "#34d399" }}>
                        <Icons.Check /> 3,030 registros nuevos insertados
                      </div>
                    )}
                  </div>
                )}
              </div>
            )}
          </div>
        </div>
      )}
    </div>
  );
}